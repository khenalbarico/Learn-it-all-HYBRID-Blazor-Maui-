@inherits LayoutComponentBase
@inject   NavigationManager Nav

<div class="app-shell">
    <div class="page-content">
        @Body
    </div>

    <nav class="bottom-nav">
        <button class="nav-item @(IsActive("") || IsActive("library") ? "active" : "")"
                @onclick='() => Nav.NavigateTo("/")'>
            <span class="nav-pip"></span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
            <span>Library</span>
        </button>

        <button class="nav-item @(IsActive("viewer") ? "active" : "")"
                @onclick='() => Nav.NavigateTo("/viewer")'>
            <span class="nav-pip"></span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
            <span>Read</span>
        </button>

        <button class="nav-item @(IsActive("account") ? "active" : "")"
                @onclick='() => Nav.NavigateTo("/account")'>
            <span class="nav-pip"></span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
            </svg>
            <span>Account</span>
        </button>
    </nav>
</div>

@code {
    private bool IsActive(string segment)
    {
        var path = new Uri(Nav.Uri).AbsolutePath.Trim('/');
        if (segment == "" || segment == "library")
            return path == "" || path == "library";
        return path.StartsWith(segment, StringComparison.OrdinalIgnoreCase);
    }
}
