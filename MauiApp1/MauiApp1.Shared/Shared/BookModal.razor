@inject AppState          State
@inject NavigationManager Nav

@if (IsVisible && Book is not null)
{
    <div class="modal-backdrop" @onclick="Close">
        <div class="modal-sheet" @onclick:stopPropagation="true">
            <button class="modal-close" @onclick="Close">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6 6 18M6 6l12 12" />
                </svg>
            </button>
            <div class="modal-cover-wrap">
                @if (!string.IsNullOrEmpty(Book.ImageUrl))
                {
                    <img src="@Book.ImageUrl" alt="@Book.Title" />
                }
                else
                {
                    <div class="modal-cover-placeholder">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                        </svg>
                    </div>
                }
            </div>
            <div class="modal-body">
                <div class="modal-price-tag @(Book.Price == 0 ? "free" : "")">
                    @(Book.Price == 0 ? "Free" : $"₱{Book.Price:N2}")
                </div>
                <h2 class="modal-title">@Book.Title</h2>
                @if (!string.IsNullOrEmpty(Book.Description))
                {
                    <p class="modal-desc">@Book.Description</p>
                }
                <button class="cta-button @(Book.Price == 0 ? "blue" : "")" @onclick="HandlePurchase">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        @if (Book.Price == 0)
                        {
                            <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2z" />
                            <path d="m9 12 2 2 4-4" />
                        }
                        else
                        {
                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                            <line x1="3" y1="6" x2="21" y2="6" />
                            <path d="M16 10a4 4 0 0 1-8 0" />
                        }
                    </svg>
                    @(Book.Price == 0 ? "Get for Free" : "Purchase Now")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool                IsVisible { get; set; }
    [Parameter] public Book?               Book      { get; set; }
    [Parameter] public EventCallback       OnClose   { get; set; }
    [Parameter] public EventCallback<Book> OnBuy     { get; set; }

    private async Task Close() => await OnClose.InvokeAsync();

    private async Task HandlePurchase()
    {
        if (Book is null) return;

        await OnClose.InvokeAsync();
        await OnBuy.InvokeAsync(Book);
    }
}