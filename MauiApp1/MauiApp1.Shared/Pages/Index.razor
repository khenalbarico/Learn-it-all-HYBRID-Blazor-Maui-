@page "/"
@using MauiApp1.Shared.Components

<div class="app-shell">
    <main class="app-content">
        @if (ActiveTab == "Library")
        {
            <Library />
        }
        else if (ActiveTab == "Previewer")
        {
            <Previewer />
        }
        else if (ActiveTab == "Account")
        {
            <Account />
        }
    </main>

    <BottomNavigation ActiveTab="@ActiveTab" ActiveTabChanged="SetActiveTab" />
</div>

@code {
    private string ActiveTab { get; set; } = "Library";

    private void SetActiveTab(string tab)
        => ActiveTab = tab; 
}