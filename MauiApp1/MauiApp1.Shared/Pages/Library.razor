@page "/"
@page "/library"
@inject IApiServices Api
@inject AppState State
@inject NavigationManager Nav
@inject IIntroBookService IntroBooks
@implements IDisposable

<div class="library-page">
    <div class="page-header">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px;">
            <img src="imgs/app_logo.png"
                 alt="Learn It All"
                 style="width:52px; height:52px; object-fit:contain;" />

            <div>
                <div style="font-size:11px; font-weight:700; letter-spacing:0.13em; text-transform:uppercase; color:var(--clr-orange); line-height:1;">
                    Learn It All
                </div>

                <div style="font-family:var(--font-display); font-size:22px; font-weight:700; color:var(--clr-ink); line-height:1.1; margin-top:2px;">
                    Knowledge Library
                </div>
            </div>
        </div>

        <p>Discover your next great read</p>
    </div>

    <div class="search-bar">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
        </svg>

        <input type="text"
               placeholder="Search books..."
               @bind="searchQuery"
               @bind:event="oninput" />
    </div>

    @if (State.Error is not null)
    {
        <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10" />
                <path d="m15 9-6 6M9 9l6 6" />
            </svg>
            <h3>Something went wrong</h3>
            <p>@State.Error</p>
        </div>
    }
    else if (!FilteredBooks.Any())
    {
        <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
            <h3>No books found</h3>
            <p>
                @(searchQuery.Length > 0
                            ? "Try a different search term."
                            : "Your library is empty right now.")
            </p>
        </div>
    }
    else
    {
        <div class="section-label">@FilteredBooks.Count() titles</div>

        @foreach (var group in GroupedBooks)
        {
            var categoryKey = group.Key;
            var allBooks = group.ToList();
            var isExpanded = expandedCategories.Contains(categoryKey);
            var showLoadAll = !isExpanded && allBooks.Count > PreviewCount;

            <div class="category-section">
                <div class="category-header">
                    <div class="category-header-inner">
                        <span class="category-icon">
                            @if (categoryKey == "Reviewer")
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 11l3 3L22 4" />
                                    <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                                </svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
                                    <path d="M6 12v5c3 3 9 3 12 0v-5" />
                                </svg>
                            }
                        </span>
                        <span class="category-label">@GetCategoryDisplayName(categoryKey)</span>
                        <span class="category-count">@allBooks.Count</span>
                    </div>
                </div>

                @if (isExpanded)
                {
                    <div class="books-grid-expanded">
                        @foreach (var book in allBooks)
                        {
                            var b = book;
                            <div class="book-card" @onclick="() => OpenBookModal(b)">
                                <div class="book-cover-wrap">
                                    <img src="@GetBookImage(b)" alt="@b.Title" loading="lazy" onerror="this.src='imgs/app_logo.png'" />
                                    <span class="book-price-badge @(b.Price == 0 ? "free" : "")">
                                        @(b.Price == 0 ? "Free" : $"₱{b.Price:N2}")
                                    </span>
                                </div>
                                <div class="book-info">
                                    <div class="book-title">@b.Title</div>
                                    @if (!string.IsNullOrEmpty(b.Description))
                                    {
                                        <div class="book-desc">@b.Description</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="load-all-wrap">
                        <button class="load-all-btn collapse" @onclick="() => CollapseCategory(categoryKey)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m18 15-6-6-6 6" />
                            </svg>
                            Show less
                        </button>
                    </div>
                }
                else
                {
                    <div class="books-scroll-row">
                        @foreach (var book in allBooks.Take(PreviewCount))
                        {
                            var b = book;
                            <div class="book-card scroll-card" @onclick="() => OpenBookModal(b)">
                                <div class="book-cover-wrap">
                                    <img src="@GetBookImage(b)" alt="@b.Title" loading="lazy" onerror="this.src='imgs/app_logo.png'" />
                                    <span class="book-price-badge @(b.Price == 0 ? "free" : "")">
                                        @(b.Price == 0 ? "Free" : $"₱{b.Price:N2}")
                                    </span>
                                </div>
                                <div class="book-info">
                                    <div class="book-title">@b.Title</div>
                                    @if (!string.IsNullOrEmpty(b.Description))
                                    {
                                        <div class="book-desc">@b.Description</div>
                                    }
                                </div>
                            </div>
                        }

                        @if (showLoadAll)
                        {
                            <div class="load-all-card" @onclick="() => ExpandCategory(categoryKey)">
                                <div class="load-all-card-inner">
                                    <div class="load-all-circle">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M5 12h14M12 5l7 7-7 7" />
                                        </svg>
                                    </div>
                                    <div class="load-all-text">
                                        <span class="load-all-count">+@(allBooks.Count - PreviewCount)</span>
                                        <span class="load-all-label">more</span>
                                    </div>
                                    <span class="load-all-sub">View all</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @if (State.CurrentUser is null)
        {
            <div class="auth-nudge">
                <div class="auth-nudge-inner">
                    <div class="auth-nudge-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                    </div>
                    <div class="auth-nudge-text">
                        <span class="auth-nudge-title">More books await</span>
                        <span class="auth-nudge-desc">Sign in to unlock the full library</span>
                    </div>
                    <button class="auth-nudge-btn" @onclick='() => Nav.NavigateTo("/auth")'>
                        Sign in
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                    </button>
                </div>
            </div>
        }
    }
</div>

<BookModal IsVisible="modalVisible"
           Book="selectedBook"
           OnClose="CloseModal"
           OnBuy="HandleBuy" />

@code {
    private const int PreviewCount = 4;

    private string searchQuery = "";
    private bool modalVisible = false;
    private Book? selectedBook = null;
    private HashSet<string> expandedCategories = new();

    private IEnumerable<Book> DisplayedBooks =>
        State.CurrentUser is not null && State.HasLoaded
            ? State.Books
            : State.IntroBooks;

    private IEnumerable<Book> FilteredBooks =>
        string.IsNullOrWhiteSpace(searchQuery)
            ? DisplayedBooks
            : DisplayedBooks.Where(b =>
                b.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                b.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<IGrouping<string, Book>> GroupedBooks =>
        FilteredBooks
            .OrderBy(b => CategoryOrder(b.Category))
            .ThenBy(b => b.Title, StringComparer.OrdinalIgnoreCase)
            .GroupBy(b => b.Category);

    private int CategoryOrder(string category) => category switch
    {
        "Reviewer" => 0,
        "CollegeCourse" => 1,
        _ => 2
    };

    private string GetCategoryDisplayName(string category) => category switch
    {
        "Reviewer" => "Reviewer",
        "CollegeCourse" => "College Course",
        _ => category
    };

    private void ExpandCategory(string key) => expandedCategories.Add(key);
    private void CollapseCategory(string key) => expandedCategories.Remove(key);

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;

        if (State.IntroBooks == null || !State.IntroBooks.Any())
        {
            var intro = await IntroBooks.LoadAsync();
            State.SetIntroBooks(intro);
        }

        if (State.CurrentUser is not null && !State.HasLoaded && !State.IsLoading)
        {
            State.SetLoading();
            try
            {
                var books = await Api.GetAllBooksAsync();
                State.SetBooks(books);
            }
            catch (Exception ex)
            {
                State.SetError(ex.Message);
            }
        }
    }

    private string GetBookImage(Book book)
    {
        if (!string.IsNullOrWhiteSpace(book.ImageUrl))
            return book.ImageUrl;

        if (!string.IsNullOrWhiteSpace(book.Uid))
            return $"imgs/introductory_imgs/{book.Uid}.png";

        return "imgs/app_logo.png";
    }

    private void OpenBookModal(Book book)
    {
        selectedBook = book;
        modalVisible = true;
    }

    private void CloseModal()
    {
        modalVisible = false;
        selectedBook = null;
    }

    private void HandleBuy(Book book)
    {
        modalVisible = false;

        if (State.CurrentUser is null)
        {
            State.PendingBook = book;
            Nav.NavigateTo("/auth");
            return;
        }

        State.SelectBook(book);
        Nav.NavigateTo("/checkout");
    }

    public void Dispose()
        => State.OnChange -= StateHasChanged;
}