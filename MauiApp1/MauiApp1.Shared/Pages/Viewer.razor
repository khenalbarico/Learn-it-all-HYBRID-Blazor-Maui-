@page "/viewer"
@inject AppState State
@inject NavigationManager Nav

<div class="viewer-page">
    @if (State.ActiveBook is null)
    {
        <div class="viewer-no-book">
            <svg width="60" height="60" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" style="opacity:0.35;">
                <g transform="translate(10,8)">
                    <path d="M50 10 L50 75 L5 95 L5 30 Z" fill="#1B6CA8" />
                    <path d="M50 10 L50 75 L95 95 L95 30 Z" fill="#1B6CA8" />
                    <path d="M50 10 L50 75 L20 90 L20 30 Z" fill="#134f7a" />
                    <path d="M50 10 L50 75 L80 90 L80 30 Z" fill="#134f7a" />
                    <path d="M50 10 C50 10 28 35 28 55 L50 75 L72 55 C72 35 50 10 50 10 Z" fill="#F7941D" />
                    <path d="M50 55 L50 78" stroke="#1A2332" stroke-width="4" stroke-linecap="round" />
                    <circle cx="50" cy="80" r="4" fill="#1A2332" />
                </g>
            </svg>
            <h3 style="font-size:22px; margin-top:8px; color:var(--clr-ink);">No book selected</h3>
            <p style="font-size:14px; color:var(--clr-text-muted); max-width:240px; line-height:1.6;">
                Go to your library and tap a book to open it here.
            </p>
            <button class="cta-button blue" style="margin:20px 0 0; width:auto; padding:14px 32px;"
                    @onclick='() => Nav.NavigateTo("/")'>
                Browse Library
            </button>
        </div>
    }
    else
    {
        var book = State.ActiveBook;

        <button class="back-button" @onclick="GoBack">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5M12 5l-7 7 7 7" />
            </svg>
            Library
        </button>

        <div class="viewer-hero">
            <div class="viewer-book-cover">
                @if (!string.IsNullOrEmpty(book.ImageUrl))
                {
                    <img src="@book.ImageUrl" alt="@book.Title" />
                }
                else
                {
                    <div style="width:100%;height:100%;background:linear-gradient(145deg,var(--clr-blue-wash),var(--clr-surface-2));display:flex;align-items:center;justify-content:center;">
                        <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" style="color:var(--clr-blue-light);">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                        </svg>
                    </div>
                }
            </div>

            <div class="viewer-book-meta">
                <span class="tag">eBook</span>
                <h2>@book.Title</h2>
                <div class="price @(book.Price == 0 ? "free" : "")">
                    @(book.Price == 0 ? "Free" : $"₱{book.Price:N2}")
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(book.Desription))
        {
            <div class="viewer-body">
                <h3>About this book</h3>
                <p>@book.Desription</p>
            </div>
            <div class="viewer-divider"></div>
        }

        <div class="viewer-body">
            <h3>Details</h3>
            <div style="margin-top:10px;">
                <div class="detail-row">
                    <span class="detail-label">Book ID</span>
                    <span class="detail-value mono">@book.Uid</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Price</span>
                    <span class="detail-value @(book.Price == 0 ? "blue" : "orange")">
                        @(book.Price == 0 ? "Free" : $"₱{book.Price:N2}")
                    </span>
                </div>
            </div>
        </div>

        <button class="cta-button">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
            @(book.Price == 0 ? "Read Now" : "Purchase & Read")
        </button>
    }
</div>

@code {
    private void GoBack()
    {
        State.ClearActiveBook();
        Nav.NavigateTo("/");
    }
}
