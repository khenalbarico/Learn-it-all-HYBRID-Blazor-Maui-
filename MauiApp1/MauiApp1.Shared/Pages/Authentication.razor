@page "/auth"
@inject IAppAuth Auth
@inject IApiServices Api
@inject AppState State
@inject NavigationManager Nav
@implements IDisposable

<div class="auth-page">

    <button class="back-button" @onclick="GoBack">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
        </svg>
        Back
    </button>

    <div class="auth-bg-orb orb-1"></div>
    <div class="auth-bg-orb orb-2"></div>

    @if (currentStep == AuthStep.Form)
    {
        <div class="auth-card">
            <div class="auth-header">
                <div class="auth-logo-wrap">
                    <img src="imgs/app_logo.png" alt="Learn It All" class="auth-logo-img" />
                </div>
                <div class="auth-brand-label">Learn It All</div>
                <h1>@(isSignUp ? "Create Account" : "Welcome Back")</h1>
                <p>@(isSignUp ? "Sign up to start your reading journey" : "Sign in to continue reading")</p>
            </div>

            <div class="auth-tabs">
                <button class="auth-tab @(!isSignUp ? "active" : "")" @onclick="() => SwitchMode(false)">Sign In</button>
                <button class="auth-tab @(isSignUp ? "active" : "")" @onclick="() => SwitchMode(true)">Sign Up</button>
                <div class="auth-tab-indicator @(isSignUp ? "right" : "")"></div>
            </div>

            <div class="auth-form">
                <div class="auth-field">
                    <label>Email Address</label>
                    <div class="auth-input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="20" height="16" x="2" y="4" rx="2" />
                            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                        </svg>
                        <input type="email" placeholder="you@email.com" @bind="email" @bind:event="oninput" />
                    </div>
                </div>

                <div class="auth-field">
                    <label>Password</label>
                    <div class="auth-input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        <input type="@(showPassword ? "text" : "password")" placeholder="••••••••" @bind="password" @bind:event="oninput" />
                        <button type="button" class="toggle-pw" @onclick="() => showPassword = !showPassword" title="@(showPassword ? "Hide password" : "Show password")">
                            @if (showPassword)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            }
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="auth-error" role="alert">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        @errorMessage
                    </div>
                }

                <button class="cta-button" @onclick="HandleSubmit" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <div class="btn-spinner"></div>
                        <span>@(isSignUp ? "Creating account..." : "Signing in...")</span>
                    }
                    else
                    {
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                            <polyline points="10 17 15 12 10 7" />
                            <line x1="15" y1="12" x2="3" y2="12" />
                        </svg>
                        <span>@(isSignUp ? "Create Account" : "Sign In")</span>
                    }
                </button>

                <div class="auth-divider">
                    <span>@(isSignUp ? "Already have an account?" : "Don't have an account?")</span>
                    <button class="auth-switch-link" @onclick="() => SwitchMode(!isSignUp)">
                        @(isSignUp ? "Sign in" : "Sign up")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (currentStep == AuthStep.VerifyEmail)
    {
        <div class="auth-card auth-notice-card">
            <div class="auth-notice-icon-wrap verify">
                <div class="auth-notice-icon-inner">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="20" height="16" x="2" y="4" rx="2" />
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                </div>
            </div>
            <h2>Check Your Email</h2>
            <p class="notice-lead">We sent a verification link to</p>
            <div class="auth-notice-email">@email</div>
            <p class="auth-notice-sub">Verify your email before signing in. Once done, come back and sign in below.</p>
            <button class="cta-button blue" @onclick="GoToSignIn">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                    <polyline points="10 17 15 12 10 7" />
                    <line x1="15" y1="12" x2="3" y2="12" />
                </svg>
                Go to Sign In
            </button>
        </div>
    }

    @if (currentStep == AuthStep.Onboarding)
    {
        <div class="auth-card auth-notice-card">
            <div class="auth-notice-icon-wrap onboard">
                <div class="auth-notice-icon-inner">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </div>
            </div>
            <h2>Welcome to<br />Learn It All</h2>
            <p class="auth-onboarding-sub">Let's set up your profile. What should we call you?</p>

            <div class="auth-form onboarding-form">
                <div class="auth-field">
                    <label>Display Name</label>
                    <div class="auth-input-wrap">
                        <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        <input type="text" placeholder="e.g. Juan dela Cruz" @bind="displayName" @bind:event="oninput" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="auth-error" role="alert">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        @errorMessage
                    </div>
                }

                <button class="cta-button" @onclick="HandleOnboarding" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <div class="btn-spinner"></div>
                        <span>Setting up...</span>
                    }
                    else
                    {
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 11 12 14 22 4" />
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                        </svg>
                        <span>Continue</span>
                    }
                </button>
            </div>
        </div>
    }

</div>

@code {
    private enum AuthStep { Form, VerifyEmail, Onboarding }

    private AuthStep currentStep = AuthStep.Form;
    private bool isSignUp = false;
    private bool isLoading = false;
    private bool showPassword = false;
    private string email = "";
    private string password = "";
    private string displayName = "";
    private string errorMessage = "";

    protected override void OnInitialized()
        => State.OnChange += StateHasChanged;

    private void SwitchMode(bool signUp)
    {
        isSignUp     = signUp;
        errorMessage = "";
    }

    private void GoBack() => Nav.NavigateTo("/");

    private void GoToSignIn()
    {
        isSignUp     = false;
        password     = "";
        errorMessage = "";
        currentStep  = AuthStep.Form;
    }

    private async Task HandleSubmit()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please fill in all fields.";
            return;
        }

        isLoading = true;

        try
        {
            if (isSignUp)
            {
                await Auth.SignUpAsync(email, password);
                currentStep = AuthStep.VerifyEmail;
            }
            else
            {
                var idToken = await Auth.SignInAsync(email, password);

                var result = new GetSignInResult(
                    UserId: GetUidFromToken(idToken),
                    Email: email,
                    DisplayName: "",
                    IdToken: idToken);

                State.SetSignInResult(result);

                var appUser = await Api.TryGetAppUser(result.UserId);

                if (appUser is null)
                {
                    currentStep = AuthStep.Onboarding;
                }
                else
                {
                    State.SetUser(appUser);
                    RedirectAfterAuth();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleOnboarding()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(displayName))
        {
            errorMessage = "Please enter your display name.";
            return;
        }

        if (State.SignInResult is null)
        {
            errorMessage = "Session expired. Please sign in again.";
            currentStep  = AuthStep.Form;
            return;
        }

        isLoading = true;

        try
        {
            var newUser = new AppUser
            {
                Uid         = State.SignInResult.UserId,
                Email       = State.SignInResult.Email,
                DisplayName = displayName
            };

            await Api.SaveAppUser(newUser);
            State.SetUser(newUser);
            RedirectAfterAuth();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void RedirectAfterAuth()
    {
        if (State.PendingBook is not null)
            Nav.NavigateTo("/viewer");
        else
            Nav.NavigateTo("/");
    }

    private static string GetUidFromToken(string idToken)
    {
        var segment = idToken.Split('.')[1];
        var padded = segment.PadRight(segment.Length + (4 - segment.Length % 4) % 4, '=');
        var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(padded));
        using var doc = System.Text.Json.JsonDocument.Parse(json);
        return doc.RootElement.GetProperty("user_id").GetString() ?? "";
    }

    public void Dispose()
        => State.OnChange -= StateHasChanged;
}
